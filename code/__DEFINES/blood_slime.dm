// States
#define BLOOD_SLIME_STATE_SOLO 0 // out of host
#define BLOOD_SLIME_STATE_DORMANT 1 // inside of a dormant (dead) host
#define BLOOD_SLIME_STATE_SUBJUGATION 2 // controlling host via subjugation
#define BLOOD_SLIME_STATE_MARIONETTE 3 // controlling host via marionette
#define BLOOD_SLIME_STATE_SYMBIOSIS 4 // in symbiosis with host
#define BLOOD_SLIME_STATE_SPLIT 5 // detached from symbiotic host
