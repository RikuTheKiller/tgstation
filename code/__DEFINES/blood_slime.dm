// States (as strings to use in assoc)
#define HEMOPARASITE_STATE_SOLO "solo" // out of host
#define HEMOPARASITE_STATE_DORMANT "dormant" // inside of a dormant (dead) host
#define HEMOPARASITE_STATE_SUBJUGATION "subjugation" // controlling host via subjugation
#define HEMOPARASITE_STATE_MARIONETTE "marionette" // controlling host via marionette
#define HEMOPARASITE_STATE_SYMBIOSIS "symbiosis" // in symbiosis with host
#define HEMOPARASITE_STATE_SPLIT "split" // detached from symbiotic host
